{
  "@context": {
    "@version": 1.1,
    "publedge": "https://publedge.org/ns/",
    "gist": "https://w3id.org/semanticarts/ns/ontology/gist/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "id": "@id",
    "type": "@type",

    "name": "schema:name",
    "description": "schema:description",
    "official_url": { "@id": "schema:url", "@type": "@id" },
    "website": { "@id": "schema:url", "@type": "@id" },

    "authority": { "@id": "gist:isSubjectOf", "@type": "@id" },
    "issuing_authority": { "@id": "gist:isSubjectOf", "@type": "@id" },
    "interpreting_authority": { "@id": "gist:isSubjectOf", "@type": "@id" },

    "jurisdiction": { "@id": "gist:hasGeographicCoverage" },
    "statute_anchors": { "@id": "gist:references", "@type": "@id", "@container": "@set" },

    "enacted": { "@id": "gist:isEnactedOn", "@type": "xsd:date" },
    "effective": { "@id": "gist:occursAt", "@type": "xsd:date" },
    "last_verified": { "@id": "publedge:lastVerified", "@type": "xsd:date" },
    "review_date": { "@id": "publedge:reviewDate", "@type": "xsd:date" },
    "term_start": { "@id": "gist:actualStartDate", "@type": "xsd:date" },
    "term_end": { "@id": "gist:actualEndDate", "@type": "xsd:date" },

    "supersedes": { "@id": "gist:replaces", "@type": "@id" },
    "status": "publedge:status",
    "kind": "publedge:kind",
    "disclaimer": "publedge:disclaimer",
    "program": "publedge:program",
    "mitigations": { "@id": "gist:hasPart", "@container": "@set" },

    "variables": { "@id": "publedge:hasVariable", "@container": "@set" },
    "fills": { "@id": "publedge:fills", "@container": "@set" }
  }
}
