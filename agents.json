{
  "$schema": "https://agentlink.run/schemas/agents-v1.json",
  "name": "PubLedge",
  "description": "Open recordkeeping protocol for fact-specific written interpretations between two parties (JIAs, RMAs, no-action letters, private letter rulings, advisory opinions). Markdown + structured frontmatter, hash-pinned, bound to Semantic Arts gist.",
  "version": "0.1.0-pre",
  "homepage": "https://publedge.org/",
  "license": {
    "content": "CC-BY-4.0",
    "code": "Apache-2.0"
  },
  "discovery": {
    "sitemap": "https://publedge.org/sitemap.xml",
    "feed": "https://publedge.org/feed.xml",
    "llms_txt": "https://publedge.org/llms.txt",
    "robots": "https://publedge.org/robots.txt"
  },
  "specification": {
    "protocol": "https://publedge.org/PROTOCOL.md",
    "prior_art": "https://publedge.org/PRIOR-ART.md",
    "vocabulary": "https://publedge.org/reference/vocabulary/",
    "manifest": "https://publedge.org/MANIFEST.yaml"
  },
  "ontology": {
    "name": "gist",
    "publisher": "Semantic Arts",
    "license": "CC-BY-4.0",
    "iri_base": "https://w3id.org/semanticarts/ns/ontology/gist/",
    "pinned_snapshot": "https://publedge.org/vendor/gist/gistCore.ttl"
  },
  "endpoints": {
    "registry": "https://publedge.org/reference/registry/",
    "templates": "https://publedge.org/tools/templates/",
    "schema": "https://publedge.org/schema/json/",
    "raw_protocol": "https://publedge.org/PROTOCOL.md"
  },
  "mcp": {
    "available": false,
    "planned": true,
    "note": "An MCP server exposing registry queries and template instantiation is planned for v0.2."
  },
  "integrity": {
    "mechanism": "SHA-256 over canonical files, tracked in MANIFEST.yaml",
    "verifier": "https://publedge.org/scripts/validate-hashes.sh",
    "ci": "Every push runs validate-hashes.sh; mismatch fails the build"
  },
  "contact": {
    "source": "https://github.com/snapsynapse/publedge",
    "issues": "https://github.com/snapsynapse/publedge/issues"
  }
}
